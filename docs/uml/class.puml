@startuml
class "code.js" as code {
  + String urlBase
  + String extension
  + int userID
  + String firstName
  + String lastName
  + function doLogin()
  + function saveCookie()
  + function readCookie()
  + function doLogout()
  + function addColor()
  + function searchColor()
}

class "MySQL/Users" as Users {
   + INT(PK) ID
   + VARCHAR(50) FirstName
   + VARCHAR(50) LastName
   + VARCHAR(50) Login
   + VARCHAR(50) Password
}
class "MySQL/Colors" as Colors {
   + INT(PK) ID
   + VARCHAR(50) Name
   + INT(FK) UserID
}

code -> Users: "Authenticates using Login.php"
code -> Colors: "Reads/Modifies API"
Users -> Colors: "1..*"
@enduml